{
  "extends": [
    "config:base",
    "docker:enableMajor"
  ],
  "docker": {
    "enabled": true,
    "files": ["Dockerfile"]
  },
  "github-actions": {
    enabled: true,
    commitMessagePrefix: "chore(deps):"
  },
  "schedule": ["at any time on sunday"],
  "assignees": ["sulthonzh"],
  "reviewers": ["sulthonzh"],
  "packageRules": {
    "matchDepTypes": ["dependencies"],
    "automerge": true
  }
}
