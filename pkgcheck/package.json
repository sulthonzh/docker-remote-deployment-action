{
  "name": "pkgcheck",
  "version": "1.0.0",
  "description": "Pre-publish checklist CLI — verify your npm package is ready before you ship",
  "main": "dist/index.js",
  "bin": {
    "pkgcheck": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsup src/index.ts src/cli.ts --format cjs --dts",
    "test": "vitest run",
    "prepublishOnly": "npm run build"
  },
  "keywords": ["npm", "publish", "checklist", "pre-publish", "validate", "package"],
  "author": "sulthonzh",
  "license": "MIT",
  "files": ["dist"],
  "types": "dist/index.d.ts",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sulthonzh/pkgcheck.git"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "vitest": "^4.0.0"
  }
}
